<?xml version="1.0"?>
<robot name="spider_bot">

  <material name="blue"><color rgba="0 0 1 1"/></material>
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.08 0 0.025" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0"/>
      <geometry><box size="0.15 0.15 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0"/>
      <geometry><box size="0.15 0.15 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/><child link="l1_c"/><origin xyz="0.1 0.1 0" rpy="0 0 0.785"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l1_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="l1_c"/><child link="l1_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/> 
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l1_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="l1_f"/><child link="l1_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/> 
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l1_t">
      <!-- 1. 中間主體：縮短長度，為前後圓柱留出空間 -->
      <visual>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.10 0.04 0.04"/></geometry> <!-- 長度從 0.14 縮至 0.10 -->
        <material name="blue"/>
      </visual>

      <!-- 2. 後端圓柱 (靠近關節 Joint 3) -->
      <visual>
        <origin xyz="0.02 0 0" rpy="1.5708 0 0"/> <!-- rpy 使圓柱橫向放置 -->
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 3. 前端圓柱 (肢體末端) -->
      <visual>
        <origin xyz="0.12 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 碰撞模型：建議維持一個簡單的長方體，這能大幅增加物理引擎的穩定性 -->
      <collision>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.14 0.04 0.04"/></geometry>
      </collision>

      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

  <joint name="joint4" type="revolute">
    <parent link="base_link"/><child link="l2_c"/><origin xyz="0 0.12 0" rpy="0 0 1.57"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l2_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="l2_c"/><child link="l2_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l2_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="l2_f"/><child link="l2_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l2_t">
    <visual><origin xyz="0.07 0 0"/><geometry><box size="0.14 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.07 0 0"/><geometry><box size="0.14 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <joint name="joint7" type="revolute">
    <parent link="base_link"/><child link="l3_c"/><origin xyz="-0.1 0.1 0" rpy="0 0 2.355"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l3_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint8" type="revolute">
    <parent link="l3_c"/><child link="l3_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l3_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint9" type="revolute">
    <parent link="l3_f"/><child link="l3_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l3_t">
      <!-- 1. 中間主體：縮短長度，為前後圓柱留出空間 -->
      <visual>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.10 0.04 0.04"/></geometry> <!-- 長度從 0.14 縮至 0.10 -->
        <material name="blue"/>
      </visual>

      <!-- 2. 後端圓柱 (靠近關節 Joint 3) -->
      <visual>
        <origin xyz="0.02 0 0" rpy="1.5708 0 0"/> <!-- rpy 使圓柱橫向放置 -->
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 3. 前端圓柱 (肢體末端) -->
      <visual>
        <origin xyz="0.12 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 碰撞模型：建議維持一個簡單的長方體，這能大幅增加物理引擎的穩定性 -->
      <collision>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.14 0.04 0.04"/></geometry>
      </collision>

      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

  <joint name="joint10" type="revolute">
    <parent link="base_link"/><child link="l4_c"/><origin xyz="-0.1 -0.1 0" rpy="0 0 -2.355"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l4_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint11" type="revolute">
    <parent link="l4_c"/><child link="l4_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l4_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint12" type="revolute">
    <parent link="l4_f"/><child link="l4_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l4_t">
      <!-- 1. 中間主體：縮短長度，為前後圓柱留出空間 -->
      <visual>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.10 0.04 0.04"/></geometry> <!-- 長度從 0.14 縮至 0.10 -->
        <material name="blue"/>
      </visual>

      <!-- 2. 後端圓柱 (靠近關節 Joint 3) -->
      <visual>
        <origin xyz="0.02 0 0" rpy="1.5708 0 0"/> <!-- rpy 使圓柱橫向放置 -->
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 3. 前端圓柱 (肢體末端) -->
      <visual>
        <origin xyz="0.12 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 碰撞模型：建議維持一個簡單的長方體，這能大幅增加物理引擎的穩定性 -->
      <collision>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.14 0.04 0.04"/></geometry>
      </collision>

      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

  <joint name="joint13" type="revolute">
    <parent link="base_link"/><child link="l5_c"/><origin xyz="0 -0.12 0" rpy="0 0 -1.57"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l5_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint14" type="revolute">
    <parent link="l5_c"/><child link="l5_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l5_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint15" type="revolute">
    <parent link="l5_f"/><child link="l5_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l5_t">
    <visual><origin xyz="0.07 0 0"/><geometry><box size="0.14 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.07 0 0"/><geometry><box size="0.14 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <joint name="joint16" type="revolute">
    <parent link="base_link"/><child link="l6_c"/><origin xyz="0.1 -0.1 0" rpy="0 0 -0.785"/><axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-1.57" upper="1.57" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l6_c">
    <visual><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.02 0 0"/><geometry><box size="0.04 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint17" type="revolute">
    <parent link="l6_c"/><child link="l6_f"/><origin xyz="0.04 0 0" rpy="0 -0.785 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l6_f">
    <visual><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></visual>
    <collision><origin xyz="0.04 0 0"/><geometry><box size="0.08 0.02 0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="joint18" type="revolute">
    <parent link="l6_f"/><child link="l6_t"/><origin xyz="0.08 0 0" rpy="0 1.57 0"/><axis xyz="0 -1 0"/>
    <limit effort="50.0" lower="-3.14" upper="3.14" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="l6_t">
      <!-- 1. 中間主體：縮短長度，為前後圓柱留出空間 -->
      <visual>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.10 0.04 0.04"/></geometry> <!-- 長度從 0.14 縮至 0.10 -->
        <material name="blue"/>
      </visual>

      <!-- 2. 後端圓柱 (靠近關節 Joint 3) -->
      <visual>
        <origin xyz="0.02 0 0" rpy="1.5708 0 0"/> <!-- rpy 使圓柱橫向放置 -->
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 3. 前端圓柱 (肢體末端) -->
      <visual>
        <origin xyz="0.12 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.02" length="0.04"/></geometry>
        <material name="blue"/>
      </visual>

      <!-- 碰撞模型：建議維持一個簡單的長方體，這能大幅增加物理引擎的穩定性 -->
      <collision>
        <origin xyz="0.07 0 0" rpy="0 0 0"/>
        <geometry><box size="0.14 0.04 0.04"/></geometry>
      </collision>

      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

  <gazebo>
      <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
        <parameters>$(find spider_bot)/config/spider_bot_controllers.yaml</parameters>
      </plugin>
      <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
        <ros>
          <namespace>/</namespace>
          <remapping>odom:=odom</remapping>
        </ros>
        <body_name>base_link</body_name>
        <frame_name>world</frame_name>
        <update_rate>50</update_rate>
      </plugin>
    </gazebo>

  <gazebo reference="base_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Blue</material>
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="l1_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="l2_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="l3_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="l4_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="l5_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="l6_t">
    <mu1>8.0</mu1> <mu2>8.0</mu2>
    <kp>10000.0</kp> <kd>100.0</kd>
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor type="depth" name="depth_camera">
      <update_rate>30.0</update_rate>
      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>3.0</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
          <remapping>custom_camera/image_raw:=camera/image_raw</remapping>
          <remapping>custom_camera/depth/image_raw:=camera/depth/image_raw</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>


  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="joint1"><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint2"><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint3"><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/></joint>
