<?xml version="1.0"?>
<robot name="hexapod_track_robot">

  <material name="blue"><color rgba="0 0 1 1"/></material>
  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="green"><color rgba="0 1 0 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>
  <material name="grey"><color rgba="0.3 0.3 0.3 1"/></material>

  <link name="base_link">
    <visual>
      <geometry><box size="0.242 0.140 0.047"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="0.235 0.135 0.045"/></geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="joint_rf_coxa" type="revolute">
    <parent link="base_link"/><child link="link_rf_coxa"/>
    <origin xyz="0.121 -0.070 0" rpy="0 0 -0.785"/>
    <axis xyz="0 0 1"/><limit lower="-1.57" upper="1.57" effort="10" velocity="3"/>
  </joint>
  <link name="link_rf_coxa">
    <visual><origin xyz="0.03425 0 0"/><geometry><box size="0.0685 0.04 0.04"/></geometry><material name="blue"/></visual>
